{
  "name": "ksp-gives-back",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npx wrangler pages dev . --d1=DB --kv=CACHE",
    "deploy": "npx wrangler pages deploy .",
    "db:init": "npx wrangler d1 execute ksp-gives-back --local --file=schema.sql",
    "db:seed": "npx wrangler d1 execute ksp-gives-back --local --file=seed.sql",
    "db:reset": "npm run db:init && npm run db:seed"
  },
  "devDependencies": {
    "wrangler": "^4"
  }
}
